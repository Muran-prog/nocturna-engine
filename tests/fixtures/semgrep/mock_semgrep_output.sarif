{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "Semgrep",
          "version": "1.75.0",
          "rules": [
            {
              "id": "python.lang.security.audit.dangerous-subprocess-use",
              "name": "dangerous-subprocess-use",
              "shortDescription": {
                "text": "Detected subprocess call with shell=True."
              },
              "fullDescription": {
                "text": "Using shell=True can allow command injection."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": ["security", "audit", "injection"],
                "cwe": ["CWE-78"],
                "owasp": ["A03:2021"],
                "confidence": "HIGH",
                "impact": "HIGH",
                "likelihood": "MEDIUM"
              },
              "helpUri": "https://semgrep.dev/r/python.lang.security.audit.dangerous-subprocess-use"
            },
            {
              "id": "javascript.lang.security.audit.detect-eval-with-expression",
              "name": "detect-eval-with-expression",
              "shortDescription": {
                "text": "Avoid dynamic eval execution."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "tags": ["security", "xss"],
                "cwe": ["CWE-79"],
                "owasp": ["A03:2021"],
                "confidence": "MEDIUM",
                "impact": "HIGH"
              },
              "helpUri": "https://semgrep.dev/r/javascript.lang.security.audit.detect-eval-with-expression"
            },
            {
              "id": "generic.secrets.aws-access-key",
              "name": "aws-access-key",
              "shortDescription": {
                "text": "Potential AWS access key in source code."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": ["secrets", "security"],
                "cwe": ["CWE-798"],
                "owasp": ["A02:2021"],
                "confidence": "HIGH",
                "impact": "HIGH"
              },
              "helpUri": "https://semgrep.dev/r/generic.secrets.aws-access-key"
            },
            {
              "id": "python.lang.security.audit.sql-injection",
              "name": "sql-injection",
              "shortDescription": {
                "text": "Potential SQL injection query."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": ["security", "injection"],
                "cwe": ["CWE-89"],
                "owasp": ["A03:2021"],
                "confidence": "HIGH",
                "impact": "HIGH"
              },
              "helpUri": "https://semgrep.dev/r/python.lang.security.audit.sql-injection"
            },
            {
              "id": "python.lang.security.audit.weak-md5-hash",
              "name": "weak-md5-hash",
              "shortDescription": {
                "text": "MD5 is cryptographically broken."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "tags": ["security", "crypto"],
                "cwe": ["CWE-327"],
                "confidence": "MEDIUM",
                "impact": "HIGH"
              },
              "helpUri": "https://semgrep.dev/r/python.lang.security.audit.weak-md5-hash"
            },
            {
              "id": "python.lang.correctness.useless-comparison",
              "name": "useless-comparison",
              "shortDescription": {
                "text": "Comparison is always true or false."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "tags": ["correctness", "best-practice"],
                "confidence": "LOW",
                "impact": "LOW"
              },
              "helpUri": "https://semgrep.dev/r/python.lang.correctness.useless-comparison"
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "python.lang.security.audit.dangerous-subprocess-use",
          "level": "error",
          "message": {
            "text": "Detected subprocess call with shell=True."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "tests/fixtures/vulnerable_code/vulnerable_python.py",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 5,
                  "startColumn": 5,
                  "endLine": 5,
                  "endColumn": 45,
                  "snippet": {
                    "text": "subprocess.call(cmd, shell=True)"
                  }
                }
              }
            }
          ],
          "fingerprints": {
            "matchBasedId/v1": "fingerprint-1"
          },
          "fixes": [
            {
              "description": {
                "text": "Use subprocess.run with shell=False."
              }
            }
          ]
        },
        {
          "ruleId": "javascript.lang.security.audit.detect-eval-with-expression",
          "level": "warning",
          "message": {
            "text": "Avoid eval() with dynamic values."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "tests/fixtures/vulnerable_code/vulnerable_js.js"
                },
                "region": {
                  "startLine": 3,
                  "startColumn": 10,
                  "endLine": 3,
                  "endColumn": 32,
                  "snippet": {
                    "text": "return eval(userInput);"
                  }
                }
              }
            }
          ],
          "fingerprints": {
            "matchBasedId/v1": "fingerprint-2"
          }
        },
        {
          "ruleId": "generic.secrets.aws-access-key",
          "level": "error",
          "message": {
            "text": "Hardcoded AWS access key detected."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "tests/fixtures/vulnerable_code/vulnerable_secrets.py"
                },
                "region": {
                  "startLine": 1,
                  "startColumn": 1,
                  "endLine": 1,
                  "endColumn": 44,
                  "snippet": {
                    "text": "AWS_ACCESS_KEY = \"AKIA1234567890ABCD\""
                  }
                }
              }
            }
          ],
          "fingerprints": {
            "matchBasedId/v1": "fingerprint-3"
          },
          "fixes": [
            {
              "description": {
                "text": "Move secret to a secure environment variable."
              }
            }
          ]
        },
        {
          "ruleId": "python.lang.security.audit.sql-injection",
          "level": "error",
          "message": {
            "text": "Potential SQL injection via f-string query."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "tests/fixtures/vulnerable_code/vulnerable_python.py"
                },
                "region": {
                  "startLine": 10,
                  "startColumn": 12,
                  "endLine": 10,
                  "endColumn": 70,
                  "snippet": {
                    "text": "query = f\"SELECT * FROM users WHERE name = '{username}'\""
                  }
                }
              }
            }
          ],
          "fingerprints": {
            "matchBasedId/v1": "fingerprint-4"
          }
        },
        {
          "ruleId": "python.lang.security.audit.weak-md5-hash",
          "level": "warning",
          "message": {
            "text": "MD5 hash function should not be used for security decisions."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "tests/fixtures/vulnerable_code/vulnerable_shell.py"
                },
                "region": {
                  "startLine": 12,
                  "startColumn": 15,
                  "endLine": 12,
                  "endColumn": 40,
                  "snippet": {
                    "text": "hashlib.md5(password.encode())"
                  }
                }
              }
            }
          ],
          "fingerprints": {
            "matchBasedId/v1": "fingerprint-5"
          }
        },
        {
          "ruleId": "python.lang.correctness.useless-comparison",
          "level": "note",
          "message": {
            "text": "Condition is always true."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "tests/fixtures/vulnerable_code/vulnerable_python.py"
                },
                "region": {
                  "startLine": 14,
                  "startColumn": 8,
                  "endLine": 14,
                  "endColumn": 21,
                  "snippet": {
                    "text": "if 1 == 1:"
                  }
                }
              }
            }
          ],
          "fingerprints": {
            "matchBasedId/v1": "fingerprint-6"
          }
        }
      ]
    }
  ]
}

